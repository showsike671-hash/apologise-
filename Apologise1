<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>For Monasree ❤️</title>

<style>
body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    text-align: center;
    background: linear-gradient(to right, #ff758c, #ff7eb3);
    color: white;
    overflow: hidden;
}

.container {
    margin-top: 50px;
    padding: 20px;
}

h1 {
    font-size: 40px;
}

#message {
    font-size: 18px;
    max-width: 600px;
    margin: 20px auto;
    min-height: 200px;
}

button {
    padding: 12px 25px;
    font-size: 18px;
    border: none;
    border-radius: 25px;
    cursor: pointer;
    margin: 10px;
}

#yes {
    background-color: #28a745;
    color: white;
}

#no {
    background-color: #dc3545;
    color: white;
    position: absolute;
}

#finalMessage {
    display: none;
    font-size: 25px;
    margin-top: 30px;
}

/* Floating hearts */
.heart {
    position: absolute;
    color: red;
    font-size: 20px;
    animation: float 5s linear infinite;
}

@keyframes float {
    0% { transform: translateY(100vh); opacity: 1; }
    100% { transform: translateY(-10vh); opacity: 0; }
}
</style>
</head>

<body>

<!-- Background Music -->
<audio autoplay loop>
  <source src="https://www.bensound.com/bensound-music/bensound-romantic.mp3" type="audio/mp3">
</audio>

<div class="container">
    <h1>I'm really sorry Monasree 🥺❤️</h1>

    <div id="message"></div>

    <h2>Will you marry me? 💍</h2>

    <button id="yes">Yes ❤️</button>
    <button id="no">No 😡</button>

    <div id="finalMessage">Yayyy 😍❤️ You made me the happiest person in the world!</div>
</div>

<script>
// Typing effect
const text = `I apologise for everything I had done till the date.

I will try to change myself and I will try to be enough mature to handle situation and you.

I will take care of you and I will be a good person and if any problem comes between us I will be the first to apologise. I won't leave my sweet girl to beg 😢, you are my first priority ❤️😢

I will definitely change myself Mona, I will be a good person here after 🙂. I don't want my sweet girl to get hurt because of me. You are the only reason I got meaning in my life. Day by day my love for you is increasing. You are the only person I need. I will wait for you. I love you ❤️`;

let i = 0;
function typeWriter() {
    if (i < text.length) {
        document.getElementById("message").innerHTML += text.charAt(i);
        i++;
        setTimeout(typeWriter, 30);
    }
}
typeWriter();

// Moving NO button
const noBtn = document.getElementById("no");
noBtn.addEventListener("mouseover", () => {
    const x = Math.random() * window.innerWidth;
    const y = Math.random() * window.innerHeight;
    noBtn.style.left = x + "px";
    noBtn.style.top = y + "px";
});

// YES button
document.getElementById("yes").onclick = function() {
    document.getElementById("finalMessage").style.display = "block";
};

// Floating hearts
setInterval(() => {
    const heart = document.createElement("div");
    heart.classList.add("heart");
    heart.innerHTML = "❤️";
    heart.style.left = Math.random() * 100 + "vw";
    document.body.appendChild(heart);

    setTimeout(() => {
        heart.remove();
    }, 5000);
}, 300);
</script>

</body>
</html>
